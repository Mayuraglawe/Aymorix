# Email account used to send notification emails (Zoho mailbox)
EMAIL_USER=info@aymorix.com

# Optional SMTP auth username if it differs from EMAIL_USER
SMTP_AUTH_USER=info@aymorix.com

# Zoho app password or mailbox SMTP password (NOT your login password if app password is enabled)
EMAIL_PASS=your-zoho-app-password

# Zoho SMTP settings
SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_SECURE=false

# Where to receive inquiry emails (defaults to EMAIL_USER if not set)
EMAIL_TO=info@aymorix.com

# Server port (default: 3000)
PORT=3000
